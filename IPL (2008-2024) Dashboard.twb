      <column caption='Total Sixes' datatype='integer' name='[Calculation_0215253610770432]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [batsman_runs]=6 THEN 1 END' />
      </column>
      <column caption='Total Four' datatype='integer' name='[Calculation_0215253611016193]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [batsman_runs] = 4 THEN 1 ELSE 0 END' />
      </column>
      <column caption='Dot Ball' datatype='integer' name='[Calculation_0215253611147266]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [total_runs] = 0 THEN 1 ELSE 0 END' />
      </column>
      <column caption='Boundary' datatype='integer' name='[Calculation_0215253611270147]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [batsman_runs] &gt;= 4 THEN 1 ELSE 0 END' />
      </column>
      <column caption='Strike Rate' datatype='real' name='[Calculation_0215253611405316]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([batsman_runs]) / COUNT([ball]) * 100' />
      </column>
      <column caption='Economy Rate' datatype='real' name='[Calculation_0215253611724805]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_runs]) / (COUNT([ball]) / 6)' />
      </column>
      <column caption='Runs Conceded' datatype='integer' name='[Calculation_0215253611900934]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_runs])' />
      </column>
      <column caption='Balls Faced' datatype='integer' name='[Calculation_0215253612527623]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([ball])' />
      </column>
      <column caption='Runs Scored' datatype='integer' name='[Calculation_0215253612687368]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([batsman_runs])' />
      </column>
      <column caption='Wickets' datatype='integer' name='[Calculation_0215253612826633]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([is_wicket])' />
      </column>
      <column caption='Match Won Toss' datatype='string' name='[Calculation_0215253613023242]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [winner] = [toss_winner] THEN &quot;Yes&quot; ELSE &quot;No&quot; END' />
      </column>
      <column caption='Home/Away' datatype='string' name='[Calculation_0215253613125643]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [team1] = [winner] THEN &quot;Team 1 Won&quot; ELSE &quot;Team 2 Won&quot; END' />
      </column>
      <column caption='Season Year' datatype='integer' name='[Calculation_0215253613285388]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='YEAR([date])' />
      </column>
      <column caption='Total Balls' datatype='integer' name='[Calculation_1302671193014272]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(ball)' />
      </column>
      <column caption='Total Batters' datatype='integer' name='[Calculation_1302671193370625]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([batter])' />
      </column>
      <column caption='Average runs' datatype='real' name='[Calculation_1302671193829378]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([batsman_runs])&#13;&#10;&#13;&#10;/&#13;&#10;&#13;&#10;COUNTD([match_id])' />
      </column>
      <column caption='Strike Rate1' datatype='real' name='[Calculation_1302671198216195]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([batsman_runs])&#13;&#10;/&#13;&#10;COUNT([ball])&#13;&#10;*100' />
      </column>
      <column caption='Player Total Runs' datatype='integer' name='[Calculation_1302671206617092]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [batter] : SUM([batsman_runs]) }' />
